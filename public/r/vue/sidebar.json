{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "sidebar",
  "type": "registry:ui",
  "description": "Collapsible sidebar with mobile drawer, tooltips, and keyboard shortcut",
  "dependencies": [
    "class-variance-authority",
    "lucide-vue-next"
  ],
  "registryDependencies": [
    "utils",
    "button",
    "sheet",
    "tooltip"
  ],
  "files": [
    {
      "path": "registry/default/ui/Sidebar.vue",
      "content": "<script setup lang=\"ts\">\nimport { inject, computed, type CSSProperties } from 'vue'\nimport { cva, type VariantProps } from 'class-variance-authority'\nimport { cn } from '@/lib/utils'\nimport { SIDEBAR_INJECTION_KEY, type SidebarContext } from './SidebarProvider.vue'\nimport Sheet from './Sheet.vue'\nimport SheetContent from './SheetContent.vue'\n\nconst SIDEBAR_WIDTH_MOBILE = '18rem'\n\nconst sidebarVariants = cva(\n  'relative flex h-full flex-col border-r-3 border-foreground bg-background transition-all duration-300 ease-out',\n  {\n    variants: {\n      collapsible: {\n        none: 'w-[var(--sidebar-width)]',\n        icon: 'w-[var(--sidebar-width)] group-data-[state=collapsed]/sidebar:w-[var(--sidebar-width-collapsed)]',\n        hidden: 'w-[var(--sidebar-width)] group-data-[state=collapsed]/sidebar:w-0 group-data-[state=collapsed]/sidebar:border-0 group-data-[state=collapsed]/sidebar:overflow-hidden',\n      },\n      side: {\n        left: '',\n        right: 'border-r-0 border-l-3',\n      },\n    },\n    defaultVariants: {\n      collapsible: 'icon',\n      side: 'left',\n    },\n  }\n)\n\ntype SidebarVariants = VariantProps<typeof sidebarVariants>\n\ninterface SidebarProps {\n  side?: SidebarVariants['side']\n  collapsible?: SidebarVariants['collapsible']\n  class?: string\n}\n\nconst props = withDefaults(defineProps<SidebarProps>(), {\n  side: 'left',\n  collapsible: 'icon',\n})\n\nconst context = inject<SidebarContext>(SIDEBAR_INJECTION_KEY)\nif (!context) {\n  throw new Error('Sidebar must be used within a SidebarProvider')\n}\n\nconst { isMobile, state, openMobile, setOpenMobile } = context\n\nconst mobileStyle = computed<CSSProperties>(() => ({\n  '--sidebar-width-mobile': SIDEBAR_WIDTH_MOBILE,\n}))\n\nconst handleMobileOpenChange = (value: boolean) => {\n  setOpenMobile(value)\n}\n</script>\n\n<template>\n  <!-- Mobile: Sheet drawer -->\n  <Sheet\n    v-if=\"isMobile.value\"\n    :open=\"openMobile.value\"\n    @update:open=\"handleMobileOpenChange\"\n  >\n    <SheetContent\n      :side=\"side === 'left' ? 'left' : 'right'\"\n      class=\"w-[var(--sidebar-width-mobile)] p-0\"\n      :style=\"mobileStyle\"\n    >\n      <div class=\"flex h-full flex-col\">\n        <slot />\n      </div>\n    </SheetContent>\n  </Sheet>\n\n  <!-- Desktop: Regular sidebar -->\n  <div\n    v-else\n    :data-state=\"state.value\"\n    :data-collapsible=\"collapsible\"\n    class=\"group/sidebar hidden md:block\"\n  >\n    <div :class=\"cn(sidebarVariants({ collapsible, side }), props.class)\">\n      <slot />\n    </div>\n  </div>\n</template>\n",
      "type": "registry:ui",
      "target": "components/ui/Sidebar.vue"
    },
    {
      "path": "registry/default/ui/SidebarContent.vue",
      "content": "<script setup lang=\"ts\">\nimport { cn } from '@/lib/utils'\n\ninterface SidebarContentProps {\n  class?: string\n}\n\nconst props = defineProps<SidebarContentProps>()\n</script>\n\n<template>\n  <div :class=\"cn('flex-1 overflow-auto p-4', props.class)\">\n    <slot />\n  </div>\n</template>\n",
      "type": "registry:ui",
      "target": "components/ui/SidebarContent.vue"
    },
    {
      "path": "registry/default/ui/SidebarFooter.vue",
      "content": "<script setup lang=\"ts\">\nimport { cn } from '@/lib/utils'\n\ninterface SidebarFooterProps {\n  class?: string\n}\n\nconst props = defineProps<SidebarFooterProps>()\n</script>\n\n<template>\n  <div\n    :class=\"cn(\n      'flex items-center border-t-3 border-foreground p-4',\n      'group-data-[state=collapsed]/sidebar:justify-center',\n      props.class\n    )\"\n  >\n    <slot />\n  </div>\n</template>\n",
      "type": "registry:ui",
      "target": "components/ui/SidebarFooter.vue"
    },
    {
      "path": "registry/default/ui/SidebarGroup.vue",
      "content": "<script setup lang=\"ts\">\nimport { cn } from '@/lib/utils'\n\ninterface SidebarGroupProps {\n  class?: string\n}\n\nconst props = defineProps<SidebarGroupProps>()\n</script>\n\n<template>\n  <div :class=\"cn('space-y-2', props.class)\">\n    <slot />\n  </div>\n</template>\n",
      "type": "registry:ui",
      "target": "components/ui/SidebarGroup.vue"
    },
    {
      "path": "registry/default/ui/SidebarGroupLabel.vue",
      "content": "<script setup lang=\"ts\">\nimport { inject, computed } from 'vue'\nimport { cn } from '@/lib/utils'\nimport { SIDEBAR_INJECTION_KEY, type SidebarContext } from './SidebarProvider.vue'\n\ninterface SidebarGroupLabelProps {\n  class?: string\n}\n\nconst props = defineProps<SidebarGroupLabelProps>()\n\nconst context = inject<SidebarContext>(SIDEBAR_INJECTION_KEY)\nconst state = computed(() => context?.state.value ?? 'expanded')\n</script>\n\n<template>\n  <div\n    :class=\"cn(\n      'px-2 py-1 text-xs font-bold uppercase tracking-wide text-muted-foreground',\n      'transition-opacity duration-200',\n      state === 'collapsed' && 'opacity-0 hidden',\n      props.class\n    )\"\n  >\n    <slot />\n  </div>\n</template>\n",
      "type": "registry:ui",
      "target": "components/ui/SidebarGroupLabel.vue"
    },
    {
      "path": "registry/default/ui/SidebarHeader.vue",
      "content": "<script setup lang=\"ts\">\nimport { cn } from '@/lib/utils'\n\ninterface SidebarHeaderProps {\n  class?: string\n}\n\nconst props = defineProps<SidebarHeaderProps>()\n</script>\n\n<template>\n  <div\n    :class=\"cn(\n      'flex items-center border-b-3 border-foreground p-4',\n      'group-data-[state=collapsed]/sidebar:justify-center',\n      props.class\n    )\"\n  >\n    <slot />\n  </div>\n</template>\n",
      "type": "registry:ui",
      "target": "components/ui/SidebarHeader.vue"
    },
    {
      "path": "registry/default/ui/SidebarInset.vue",
      "content": "<script setup lang=\"ts\">\nimport { cn } from '@/lib/utils'\n\ninterface SidebarInsetProps {\n  class?: string\n}\n\nconst props = defineProps<SidebarInsetProps>()\n</script>\n\n<template>\n  <div :class=\"cn('flex-1 overflow-auto', props.class)\">\n    <slot />\n  </div>\n</template>\n",
      "type": "registry:ui",
      "target": "components/ui/SidebarInset.vue"
    },
    {
      "path": "registry/default/ui/SidebarItem.vue",
      "content": "<script setup lang=\"ts\">\nimport { inject, computed, useSlots } from 'vue'\nimport { cva, type VariantProps } from 'class-variance-authority'\nimport { cn } from '@/lib/utils'\nimport { SIDEBAR_INJECTION_KEY, type SidebarContext } from './SidebarProvider.vue'\nimport Tooltip from './Tooltip.vue'\nimport TooltipTrigger from './TooltipTrigger.vue'\nimport TooltipContent from './TooltipContent.vue'\n\nconst sidebarItemVariants = cva(\n  'flex w-full items-center gap-3 px-3 py-2 text-sm transition-all duration-150',\n  {\n    variants: {\n      variant: {\n        default: 'hover:bg-muted',\n        active: 'bg-accent shadow-[4px_4px_0px_hsl(var(--shadow-color))]',\n      },\n    },\n    defaultVariants: {\n      variant: 'default',\n    },\n  }\n)\n\ntype SidebarItemVariants = VariantProps<typeof sidebarItemVariants>\n\ninterface SidebarItemProps {\n  variant?: SidebarItemVariants['variant']\n  tooltip?: string\n  class?: string\n}\n\nconst props = withDefaults(defineProps<SidebarItemProps>(), {\n  variant: 'default',\n})\n\nconst slots = useSlots()\n\nconst context = inject<SidebarContext>(SIDEBAR_INJECTION_KEY)\nconst isCollapsed = computed(() => context?.state.value === 'collapsed')\n\nconst buttonClasses = computed(() =>\n  cn(\n    sidebarItemVariants({ variant: props.variant }),\n    isCollapsed.value && 'justify-center px-2',\n    props.class\n  )\n)\n</script>\n\n<template>\n  <!-- With Tooltip when collapsed -->\n  <Tooltip v-if=\"isCollapsed.value && tooltip\">\n    <TooltipTrigger>\n      <button :class=\"buttonClasses\">\n        <span v-if=\"slots.icon\" class=\"shrink-0\">\n          <slot name=\"icon\" />\n        </span>\n      </button>\n    </TooltipTrigger>\n    <TooltipContent side=\"right\">\n      {{ tooltip }}\n    </TooltipContent>\n  </Tooltip>\n\n  <!-- Without Tooltip -->\n  <button v-else :class=\"buttonClasses\">\n    <span v-if=\"slots.icon\" class=\"shrink-0\">\n      <slot name=\"icon\" />\n    </span>\n    <span v-if=\"!isCollapsed.value\" class=\"truncate\">\n      <slot />\n    </span>\n  </button>\n</template>\n",
      "type": "registry:ui",
      "target": "components/ui/SidebarItem.vue"
    },
    {
      "path": "registry/default/ui/SidebarProvider.vue",
      "content": "<script setup lang=\"ts\">\nimport { provide, ref, computed, readonly, onMounted, onUnmounted, type CSSProperties } from 'vue'\nimport { cn } from '@/lib/utils'\n\nconst SIDEBAR_COOKIE_NAME = 'sidebar:state'\nconst SIDEBAR_COOKIE_MAX_AGE = 60 * 60 * 24 * 7 // 7 days\nconst SIDEBAR_WIDTH = '16rem'\nconst SIDEBAR_WIDTH_COLLAPSED = '4rem'\nconst SIDEBAR_KEYBOARD_SHORTCUT = 'b'\n\nexport interface SidebarContext {\n  state: ReturnType<typeof computed<'expanded' | 'collapsed'>>\n  open: ReturnType<typeof computed<boolean>>\n  setOpen: (value: boolean) => void\n  openMobile: Readonly<ReturnType<typeof ref<boolean>>>\n  setOpenMobile: (value: boolean) => void\n  isMobile: Readonly<ReturnType<typeof ref<boolean>>>\n  toggleSidebar: () => void\n}\n\nexport const SIDEBAR_INJECTION_KEY = Symbol('sidebar')\n\ninterface SidebarProviderProps {\n  defaultOpen?: boolean\n  open?: boolean\n  class?: string\n}\n\nconst props = withDefaults(defineProps<SidebarProviderProps>(), {\n  defaultOpen: true,\n  open: undefined,\n})\n\nconst emit = defineEmits<{\n  'update:open': [value: boolean]\n}>()\n\nconst uncontrolledOpen = ref(props.defaultOpen)\nconst openMobile = ref(false)\nconst isMobile = ref(false)\n\nconst isControlled = computed(() => props.open !== undefined)\nconst currentOpen = computed(() => isControlled.value ? props.open! : uncontrolledOpen.value)\n\nconst setOpen = (value: boolean) => {\n  if (!isControlled.value) {\n    uncontrolledOpen.value = value\n  }\n  emit('update:open', value)\n\n  // Save to cookie\n  if (typeof document !== 'undefined') {\n    document.cookie = `${SIDEBAR_COOKIE_NAME}=${value}; path=/; max-age=${SIDEBAR_COOKIE_MAX_AGE}`\n  }\n}\n\nconst setOpenMobile = (value: boolean) => {\n  openMobile.value = value\n}\n\nconst toggleSidebar = () => {\n  if (isMobile.value) {\n    openMobile.value = !openMobile.value\n  } else {\n    setOpen(!currentOpen.value)\n  }\n}\n\nconst state = computed<'expanded' | 'collapsed'>(() => currentOpen.value ? 'expanded' : 'collapsed')\n\n// Check if mobile\nconst checkMobile = () => {\n  if (typeof window !== 'undefined') {\n    isMobile.value = window.innerWidth < 768\n  }\n}\n\n// Keyboard shortcut handler\nconst handleKeyDown = (e: KeyboardEvent) => {\n  if (\n    e.key === SIDEBAR_KEYBOARD_SHORTCUT &&\n    (e.metaKey || e.ctrlKey) &&\n    !e.shiftKey &&\n    !e.altKey\n  ) {\n    e.preventDefault()\n    toggleSidebar()\n  }\n}\n\nonMounted(() => {\n  checkMobile()\n  window.addEventListener('resize', checkMobile)\n  window.addEventListener('keydown', handleKeyDown)\n})\n\nonUnmounted(() => {\n  window.removeEventListener('resize', checkMobile)\n  window.removeEventListener('keydown', handleKeyDown)\n})\n\nprovide(SIDEBAR_INJECTION_KEY, {\n  state,\n  open: currentOpen,\n  setOpen,\n  openMobile: readonly(openMobile),\n  setOpenMobile,\n  isMobile: readonly(isMobile),\n  toggleSidebar,\n})\n\nconst cssVars = computed<CSSProperties>(() => ({\n  '--sidebar-width': SIDEBAR_WIDTH,\n  '--sidebar-width-collapsed': SIDEBAR_WIDTH_COLLAPSED,\n}))\n</script>\n\n<template>\n  <div\n    :style=\"cssVars\"\n    :class=\"cn(\n      'group/sidebar-wrapper flex min-h-screen w-full',\n      props.class\n    )\"\n  >\n    <slot />\n  </div>\n</template>\n",
      "type": "registry:ui",
      "target": "components/ui/SidebarProvider.vue"
    },
    {
      "path": "registry/default/ui/SidebarSeparator.vue",
      "content": "<script setup lang=\"ts\">\nimport { cn } from '@/lib/utils'\n\ninterface SidebarSeparatorProps {\n  class?: string\n}\n\nconst props = defineProps<SidebarSeparatorProps>()\n</script>\n\n<template>\n  <div :class=\"cn('mx-2 h-[3px] bg-foreground', props.class)\" />\n</template>\n",
      "type": "registry:ui",
      "target": "components/ui/SidebarSeparator.vue"
    },
    {
      "path": "registry/default/ui/SidebarToggle.vue",
      "content": "<script setup lang=\"ts\">\nimport { inject, computed } from 'vue'\nimport { PanelLeft } from 'lucide-vue-next'\nimport { cn } from '@/lib/utils'\nimport { SIDEBAR_INJECTION_KEY, type SidebarContext } from './SidebarProvider.vue'\nimport Button from './Button.vue'\n\ninterface SidebarToggleProps {\n  class?: string\n}\n\nconst props = defineProps<SidebarToggleProps>()\n\nconst context = inject<SidebarContext>(SIDEBAR_INJECTION_KEY)\nif (!context) {\n  throw new Error('SidebarToggle must be used within a SidebarProvider')\n}\n\nconst { toggleSidebar, state } = context\n\nconst isCollapsed = computed(() => state.value === 'collapsed')\n</script>\n\n<template>\n  <Button\n    variant=\"outline\"\n    size=\"icon\"\n    :class=\"cn('h-8 w-8 transition-transform duration-300', props.class)\"\n    @click=\"toggleSidebar\"\n  >\n    <PanelLeft\n      :class=\"cn(\n        'h-4 w-4 transition-transform duration-300',\n        isCollapsed.value && 'rotate-180'\n      )\"\n    />\n    <span class=\"sr-only\">Toggle Sidebar</span>\n  </Button>\n</template>\n",
      "type": "registry:ui",
      "target": "components/ui/SidebarToggle.vue"
    }
  ]
}